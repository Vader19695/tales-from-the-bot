---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config';
import { formatDateTime } from '../../utils/format-date';
import { buildExcerpt } from '../../utils/excerpt';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map((story) => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

interface Props {
  story: CollectionEntry<'stories'>;
}

const { story } = Astro.props;
const { Content } = await story.render();
const { title, date, model, prompt, humanPrompt, editedAt } = story.data;

const formattedDate = formatDateTime(date);
const formattedEditedAt = editedAt ? formatDateTime(editedAt) : null;

const canonicalUrl = new URL(`/stories/${story.slug}`, siteConfig.url).href;
const excerpt = buildExcerpt(story.body);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: excerpt,
  datePublished: date.toISOString(),
  ...(editedAt ? { dateModified: editedAt.toISOString() } : {}),
  author: {
    '@type': 'Organization',
    name: siteConfig.title,
    url: siteConfig.url,
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.title,
    url: siteConfig.url,
  },
  url: canonicalUrl,
  isAccessibleForFree: true,
// Escape </ to prevent </script> in story content from breaking out of the
// script tag. Forward slashes are safely escapable in JSON (RFC 8259 §7).
}).replace(/<\//g, '<\\/');
---

<BaseLayout title={title} description={excerpt} canonicalUrl={canonicalUrl} ogType="article">
  <script type="application/ld+json" set:html={jsonLd} slot="head" />
  <article>
    <header class="story-header">
      <div class="story-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span>· Written by <code>{model}</code></span>
        {humanPrompt && <span class="tag-human-prompt">Human prompt</span>}
        {formattedEditedAt && <span class="story-edited">· Edited {formattedEditedAt}</span>}
      </div>

      <h1>{title}</h1>

      <!-- Prompt block — readers can see exactly what was asked of the AI. -->
      <details class="prompt-block">
        <summary>View prompt sent to the AI</summary>
        <pre>{prompt}</pre>
      </details>
    </header>

    <div class="story-body">
      <Content />
    </div>
  </article>

  <nav style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
    <a href="/" style="font-size: 0.9rem; color: var(--color-muted); text-decoration: none;">
      ← All stories
    </a>
  </nav>
</BaseLayout>
