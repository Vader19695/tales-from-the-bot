---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map((story) => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

interface Props {
  story: CollectionEntry<'stories'>;
}

const { story } = Astro.props;
const { Content } = await story.render();
const { title, date, model, prompt, humanPrompt } = story.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalUrl = new URL(`/stories/${story.slug}`, siteConfig.url).href;
---

<BaseLayout title={title} description={`${title} — an AI-generated short story.`} canonicalUrl={canonicalUrl}>
  <article>
    <header class="story-header">
      <div class="story-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span>· Written by <code>{model}</code></span>
        {humanPrompt && <span class="tag-human-prompt">Human prompt</span>}
      </div>

      <h1>{title}</h1>

      <!-- Prompt block — readers can see exactly what was asked of the AI. -->
      <details class="prompt-block">
        <summary>View prompt sent to the AI</summary>
        <pre>{prompt}</pre>
      </details>
    </header>

    <div class="story-body">
      <Content />
    </div>
  </article>

  <nav style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
    <a href="/" style="font-size: 0.9rem; color: var(--color-muted); text-decoration: none;">
      ← All stories
    </a>
  </nav>
</BaseLayout>
