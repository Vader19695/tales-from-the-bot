---
import type { CollectionEntry } from 'astro:content';
import { formatDateTime } from '../utils/format-date';
import { buildExcerpt } from '../utils/excerpt';

interface Props {
  story: CollectionEntry<'stories'>;
}

const { story } = Astro.props;
const { title, date, model, humanPrompt, editedAt } = story.data;

const excerpt = buildExcerpt(story.body);

const formattedDate = formatDateTime(date);
const formattedEditedAt = editedAt ? formatDateTime(editedAt) : null;
---

<article class="story-card">
  <div class="story-meta">
    <time datetime={date.toISOString()}>{formattedDate}</time>
    <span>· {model}</span>
    {humanPrompt && <span class="tag-human-prompt">Human prompt</span>}
    {formattedEditedAt && <span class="story-edited">· Edited {formattedEditedAt}</span>}
  </div>
  <h2><a href={`/stories/${story.slug}`}>{title}</a></h2>
  <p class="story-excerpt">{excerpt}</p>
  <a href={`/stories/${story.slug}`} class="read-more">Read story →</a>
</article>
