---
import type { CollectionEntry } from 'astro:content';

interface Props {
  story: CollectionEntry<'stories'>;
}

const { story } = Astro.props;
const { title, date, model, prompt } = story.data;

// Build excerpt from the raw body (strip markdown syntax for a clean preview).
const excerpt =
  story.body
    ?.replace(/#{1,6}\s+/g, '')
    .replace(/[*_`~]/g, '')
    .replace(/\n+/g, ' ')
    .trim()
    .slice(0, 200)
    .concat('…') ?? '';

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="story-card">
  <div class="story-meta">
    <time datetime={date.toISOString()}>{formattedDate}</time>
    <span>· {model}</span>
  </div>
  <h2><a href={`/stories/${story.slug}`}>{title}</a></h2>
  <p class="story-excerpt">{excerpt}</p>
  <a href={`/stories/${story.slug}`} class="read-more">Read story →</a>
</article>
