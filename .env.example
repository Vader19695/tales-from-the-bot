# Copy this file to .env and fill in your values for local development.
# Never commit .env to version control.

# Anthropic API key — required to run scripts/generate-story.ts locally.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# LLM model to use (default: claude-opus-4-5).
# Other options: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
# For OpenAI: set this to gpt-4o and swap the provider in scripts/generate-story.ts.
LLM_MODEL=claude-opus-4-5

# Commit mode: "pr" opens a pull request, "direct" commits directly to main.
COMMIT_MODE=pr

# ── Analytics ──────────────────────────────────────────────────────────────────
# Set the active provider and the relevant tracking ID for that provider.
# These are read at build time — values are baked into the static HTML output.
# Leave unset to use the defaults in src/config.ts.

# Active provider: plausible | ga4 | fathom | umami | none
ANALYTICS_PROVIDER=plausible

# Plausible — domain registered on plausible.io (must match exactly)
PLAUSIBLE_DOMAIN=talesfromthebot.blog

# Google Analytics 4 — Measurement ID from the GA4 dashboard
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Fathom — Site ID from the Fathom dashboard
FATHOM_SITE_ID=

# Umami — Website ID from the Umami dashboard
UMAMI_WEBSITE_ID=
