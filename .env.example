# Copy this file to .env and fill in your values for local development.
# Never commit .env to version control.

# Anthropic API key — required to run scripts/generate-story.ts locally.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# LLM model to use (default: claude-opus-4-5).
# Other options: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
# For OpenAI: set this to gpt-4o and swap the provider in scripts/generate-story.ts.
LLM_MODEL=claude-opus-4-5

# Commit mode: "pr" opens a pull request, "direct" commits directly to main.
COMMIT_MODE=pr
